@prefix : <https://appsudara.github.io/doisr-g5.github.io/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


# CONTROLLED VOCABULARY
:Male a :GenderCategory .
:Female a :GenderCategory .

:Drama a :Genre .
:Comedy a :Genre .
:Action a :Genre .

:English a :Language .
:Spanish a :Language .


# VALID DATA
:actor1
    a :Actor ;
    rdf:name "Leonardo DiCaprio" ;
    rdf:age 48 ;
    rdf:birth "1974-11-11"^^xsd:date ;
    rdf:hasGender :Male ;
    rdf:debutedIn :movie1 .

:director1
    a :Director ;
    rdf:name "Christopher Nolan" ;
    rdf:age 53 ;
    rdf:birth "1970-07-30"^^xsd:date ;
    rdf:hasGender :Male ;
    rdf:directorialDebut :movie1 .

:producer1
    a :Producer ;
    rdf:name "Emma Thomas" ;
    rdf:age 52 ;
    rdf:hasGender :Female ;
    rdf:producerDebut :movie1 .

:review1
    a :Review ;
    rdf:reviewText "An excellent science fiction movie with amazing visuals." .

:movie1
    a :Movie ;
    rdf:movieTitle "Inception" ;
    rdf:budgetAmount "160000000"^^xsd:decimal ;
    rdf:releaseDate "2010-07-16"^^xsd:date ;
    rdf:durationMinutes 148 ;
    rdf:hasActor :actor1 ;
    rdf:hasDirector :director1 ;
    rdf:hasProducer :producer1 ;
    rdf:belongsToGenre :Action ;
    rdf:hasOriginalLanguage :English ;
    rdf:hasReview :review1 .


# INVALID MOVIE — wrong datatype + negative value
:movie2
    a :Movie ;
    rdf:movieTitle 123 ;
    rdf:budgetAmount -500 ;
    rdf:releaseDate "not-a-date" ;
    rdf:durationMinutes -20 ;
    rdf:hasDirector :director1 ;
    rdf:hasProducer :producer1 ;
    rdf:belongsToGenre :Drama ;
    rdf:hasOriginalLanguage :English .


# INVALID MOVIE — missing required properties
:movie3
    a :Movie ;
    rdf:budgetAmount "50000000"^^xsd:decimal .


# INVALID MOVIE — actor is not an Actor instance
:movie4
    a :Movie ;
    rdf:movieTitle "Fake Movie" ;
    rdf:releaseDate "2020-01-01"^^xsd:date ;
    rdf:budgetAmount "1000000"^^xsd:decimal ;
    rdf:durationMinutes 100 ;
    rdf:hasActor "Bob8" ;
    rdf:hasDirector :director1 ;
    rdf:hasProducer :producer1 ;
    rdf:belongsToGenre :Drama ;
    rdf:hasOriginalLanguage :English .


# INVALID ACTOR — negative age + missing gender
:actor2
    a :Actor ;
    rdf:name "Not Real" ;
    rdf:age -10 .


# INVALID REVIEW — text too short
:review2
    a :Review ;
    rdf:reviewText "Bad" .

# INVALID DIRECTOR — multiple debut movies
:director2
    a :Director ;
    rdf:name "Fake Person" ;
    rdf:age 45 ;
    rdf:hasGender :Male ;
    rdf:directorialDebut :movie1 ;
    rdf:directorialDebut :movie2 .


# INVALID PRODUCER — multiple producer debuts
:producer2
    a :Producer ;
    rdf:name "Fake Producer" ;
    rdf:age 40 ;
    rdf:hasGender :Male ;
    rdf:producerDebut :movie1 ;
    rdf:producerDebut :movie2 .
