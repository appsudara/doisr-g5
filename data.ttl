@prefix ns: <https://asudara.dev/doisrg5/movie#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


# CONTROLLED VOCABULARY

ns:Male a ns:GenderCategory .
ns:Female a ns:GenderCategory .

ns:Drama a ns:Genre .
ns:Comedy a ns:Genre .
ns:Action a ns:Genre .

ns:English
    a ns:Language ;
    ns:languageCode "en" .

ns:Spanish
    a ns:Language ;
    ns:languageCode "es" .



# VALID DATA

ns:actor1
    a ns:Actor ;
    ns:personName "Leonardo DiCaprio" ;
    ns:ageValue 48 ;
    ns:hasGender ns:Male ;
    ns:debutedIn ns:movie1 .

ns:director1
    a ns:Director ;
    ns:personName "Christopher Nolan" ;
    ns:ageValue 53 ;
    ns:hasGender ns:Male ;
    ns:directorialDebut ns:movie1 .

ns:producer1
    a ns:Producer ;
    ns:personName "Emma Thomas" ;
    ns:ageValue 52 ;
    ns:hasGender ns:Female ;
    ns:producerDebut ns:movie1 .

ns:review1
    a ns:Review ;
    ns:reviewText "An excellent science fiction movie." .

ns:movie1
    a ns:Movie ;
    ns:movieTitle "Inception" ;
    ns:budgetAmount "160000000"^^xsd:decimal ;
    ns:releaseDate "2010-07-16"^^xsd:date ;
    ns:hasActor ns:actor1 ;
    ns:hasDirector ns:director1 ;
    ns:hasProducer ns:producer1 ;
    ns:belongsToGenre ns:Action ;
    ns:hasOriginalLanguage ns:English ;
    ns:hasReview ns:review1 .


# INVALID MOVIE — wrong datatype + negative value


ns:movie2
    a ns:Movie ;
    ns:movieTitle 123 ;
    ns:budgetAmount -500 ;
    ns:releaseDate "not-a-date" ;
    ns:hasDirector ns:director1 ;
    ns:hasProducer ns:producer1 ;
    ns:belongsToGenre ns:Drama ;
    ns:hasOriginalLanguage ns:English .


# INVALID MOVIE — missing required properties

ns:movie3
    a ns:Movie ;
    ns:budgetAmount "50000000"^^xsd:decimal .


# INVALID MOVIE — actor is not an Actor instance

ns:movie4
    a ns:Movie ;
    ns:movieTitle "Fake Movie" ;
    ns:releaseDate "2020-01-01"^^xsd:date ;
    ns:budgetAmount "1000000"^^xsd:decimal ;
    ns:hasActor "Bob8" ;
    ns:hasDirector ns:director1 ;
    ns:hasProducer ns:producer1 ;
    ns:belongsToGenre ns:Drama ;
    ns:hasOriginalLanguage ns:English .


# INVALID ACTOR — negative age + missing gender

ns:actor2
    a ns:Actor ;
    ns:personName "Not Real" ;
    ns:ageValue -10 .


# INVALID REVIEW — text too short

ns:review2
    a ns:Review ;
    ns:reviewText "Bad" .


# INVALID LANGUAGE — invalid language code

ns:German
    a ns:Language ;
    ns:languageCode "german" .


# INVALID DIRECTOR — multiple debut movies


ns:director2
    a ns:Director ;
    ns:personName "Fake Person" ;
    ns:ageValue 45 ;
    ns:hasGender ns:Male ;
    ns:directorialDebut ns:movie1 ;
    ns:directorialDebut ns:movie2 .


# INVALID PRODUCER — multiple producer debuts


ns:producer2
    a ns:Producer ;
    ns:personName "Fake Producer" ;
    ns:ageValue 40 ;
    ns:hasGender ns:Male ;
    ns:producerDebut ns:movie1 ;
    ns:producerDebut ns:movie2 .
