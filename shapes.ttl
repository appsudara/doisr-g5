@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix : <https://appsudara.github.io/doisr-g5.github.io/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


# Shape 1: MovieShape
:MovieShape
    a sh:NodeShape ;
    sh:targetClass :Movie ;

    sh:property [
        sh:path rdf:movieTitle ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path rdf:releaseDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path rdf:budgetAmount ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
    ] ;

    sh:property [
        sh:path rdf:durationMinutes ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
    ] ;

    sh:property [
        sh:path rdf:hasActor ;
        sh:class :Actor ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdf:hasDirector ;
        sh:class :Director ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdf:hasProducer ;
        sh:class :Producer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdf:belongsToGenre ;
        sh:class :Genre ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdf:hasOriginalLanguage ;
        sh:class :Language ;
        sh:minCount 1 ;
    ] .


# Shape 2: PersonShape
:PersonShape
    a sh:NodeShape ;
    sh:targetClass :Person ;

    sh:property [
        sh:path rdf:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdf:age ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:maxInclusive 120 ;
    ] ;

    sh:property [
        sh:path rdf:birth ;
        sh:datatype xsd:date ;
    ] ;

    sh:property [
        sh:path rdf:hasGender ;
        sh:class :GenderCategory ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .


# Shape 3: ActorShape
:ActorShape
    a sh:NodeShape ;
    sh:targetClass :Actor ;

    sh:property [
        sh:path rdf:debutedIn ;
        sh:class :Movie ;
        sh:maxCount 1 ;
    ] .


# Shape 4: DirectorShape
:DirectorShape
    a sh:NodeShape ;
    sh:targetClass :Director ;

    sh:property [
        sh:path rdf:directorialDebut ;
        sh:class :Movie ;
        sh:maxCount 1 ;
    ] .


# Shape 5: ProducerShape
:ProducerShape
    a sh:NodeShape ;
    sh:targetClass :Producer ;

    sh:property [
        sh:path rdf:producerDebut ;
        sh:class :Movie ;
        sh:maxCount 1 ;
    ] .


# Shape 6: ReviewShape
:ReviewShape
    a sh:NodeShape ;
    sh:targetClass :Review ;

    sh:property [
        sh:path rdf:reviewText ;
        sh:datatype xsd:string ;
        sh:minLength 10 ;
        sh:maxLength 500 ;
        sh:minCount 1 ;
    ] .


# Shape 7: GenreShape
:GenreShape
    a sh:NodeShape ;
    sh:targetClass :Genre ;

    sh:in (
        rdf:genreLabel
    ) .


# Shape 8: LanguageShape
:LanguageShape
    a sh:NodeShape ;
    sh:targetClass :Language ;

    sh:in (
        rdf:languageLabel
    ) .
